generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Category {
  BILLING
  TECHNICAL
  ACCOUNT
  GENERAL
}

enum TicketStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  tickets   Ticket[]
  createdAt DateTime @default(now())
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String       @db.Text
  status      TicketStatus @default(PENDING)

  // AI Generated Metadata
  category    Category?
  priority    Priority?

  // Link to User model
  userId      String
  user        User         @relation(fields: [userId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([category])
  @@index([priority])
}